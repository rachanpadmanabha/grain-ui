{
  "name": "grain-ui",
  "version": "0.1.0",
  "description": "Ultra-lightweight semantic HTML/CSS/JS UI library. No dependencies, no build step.",
  "keywords": [
    "ui",
    "css",
    "design-system",
    "web-components",
    "semantic",
    "lightweight"
  ],
  "homepage": "https://github.com/rachanpadmanabha/grain-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rachanpadmanabha/grain-ui.git"
  },
  "bugs": {
    "url": "https://github.com/rachanpadmanabha/grain-ui/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/grain.js",
  "module": "./dist/grain.js",
  "style": "./dist/grain.css",
  "exports": {
    ".": "./dist/grain.js",
    "./css": "./dist/grain.css",
    "./min": "./dist/grain.min.js",
    "./min.css": "./dist/grain.min.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/tokens.css",
    "src/base.css",
    "src/components/",
    "src/index.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css",
    "*.js"
  ],
  "scripts": {
    "build": "make all",
    "dev": "make all && npx serve .",
    "prepublishOnly": "make all",
    "size": "ls -lh dist"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "lightningcss-cli": "^1.30.2",
    "serve": "^14.2.3"
  },
  "engines": {
    "node": ">=18"
  }
}
